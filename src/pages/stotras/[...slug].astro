---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { postCanonicalURL } from '../../lib/postUrls';
import HanumanChalisaSeoTags from '../../components/HanumanChalisaSeoTags.astro';
import StotraLanguageLinks from '../../components/StotraLanguageLinks.astro';

export async function getStaticPaths() {
	const posts = await getCollection('stotras');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'stotras'>;

const post = Astro.props;
const { Content } = await render(post);
const canonicalURL = postCanonicalURL(post, Astro.site);
const showHanumanLanguageIndex = post.id === 'hanuman-chalisa-telugu';
const hanumanStructuredData = showHanumanLanguageIndex
	? {
			'@context': 'https://schema.org',
			'@type': 'CreativeWork',
			name: post.data.title,
			headline: post.data.title,
			description: post.data.description,
			url: canonicalURL,
			inLanguage: ['te-IN', 'en-IN', 'hi-IN', 'ta-IN', 'kn-IN', 'ml-IN', 'gu-IN', 'or-IN', 'bn-IN', 'mr-IN', 'as-IN', 'pa-IN', 'sa-IN', 'ne-NP', 'si-LK'],
			alternateName: [
				'Hanuman Chalisa English lyrics',
				'Hanuman Chalisa Devanagari',
				'Hanuman Chalisa Telugu lyrics',
				'Hanuman Chalisa Tamil lyrics',
				'Hanuman Chalisa Kannada lyrics',
				'Hanuman Chalisa Malayalam lyrics',
				'Hanuman Chalisa Gujarati lyrics',
				'Hanuman Chalisa Odia lyrics',
				'Hanuman Chalisa Bengali lyrics',
				'Hanuman Chalisa Marathi lyrics',
				'Hanuman Chalisa Assamese lyrics',
				'Hanuman Chalisa Punjabi lyrics',
				'Hanuman Chalisa Hindi lyrics',
				'Hanuman Chalisa Sanskrit lyrics',
				'Hanuman Chalisa Nepali lyrics',
				'Hanuman Chalisa Sinhala lyrics',
				'Hanuman Chalisa Grantha',
			],
			genre: ['Stotra', 'Devotional lyrics', 'Hindu prayer'],
			datePublished: post.data.pubDate.toISOString(),
			dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
		}
	: undefined;

const adSlots = [
	{ slot: '7608753970', label: 'Sponsored Advertisement' },
	{ slot: '1924008995', label: 'Sponsored Advertisement' },
	{ slot: '4981061956', label: 'Sponsored Advertisement' },
];
---

<BlogPost {...post.data} adSlots={adSlots} canonicalURL={canonicalURL} structuredData={hanumanStructuredData}>
	<Content />
	<StotraLanguageLinks post={post} />
	{showHanumanLanguageIndex && <HanumanChalisaSeoTags />}
</BlogPost>
