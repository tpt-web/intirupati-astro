---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

const { title, description, pubDate, updatedDate, heroImage, relatedLinks = [] } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			ogType="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
		<!-- Font Awesome for tools -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
	</head>

	<body class="bg-gray-50 text-gray-900 font-sans min-h-screen flex flex-col">
		<Header />
		
		<main class="flex-grow py-8 px-4 sm:px-6 lg:px-8">
			<article class="max-w-5xl mx-auto">
				{heroImage && (
					<div class="mb-8 rounded-xl overflow-hidden shadow-md max-w-4xl mx-auto">
						<img class="w-full h-auto object-cover max-h-[400px]" src={heroImage} alt={title} />
					</div>
				)}
				
				<div class="max-w-4xl mx-auto text-center mb-8">
					<h1 class="text-3xl sm:text-4xl font-extrabold text-gray-950 tracking-tight mb-4">
						{title}
					</h1>
					{pubDate && (
						<div class="text-sm text-gray-500 flex justify-center gap-2 items-center">
							<span>Published:</span>
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<>
									<span class="mx-1">&middot;</span>
									<span>Updated:</span>
									<FormattedDate date={updatedDate} />
								</>
							)}
						</div>
					)}
					<hr class="mt-6 border-gray-250" />
				</div>

				<!-- Dynamic Content Slot (Tool component goes here) -->
				<div class="my-6">
					<slot name="tool" />
				</div>

				<!-- SEO Copywriting / Article Content -->
				<div class="prose prose-slate prose-lg max-w-3xl mx-auto mt-12 pt-8 border-t border-gray-200">
					<slot />
					<RelatedLinks links={relatedLinks} />
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>
