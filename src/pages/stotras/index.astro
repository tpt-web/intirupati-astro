---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const stotras = (await getCollection('stotras')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead
			title={`List of Stotras - స్తోత్రాలు - ${SITE_TITLE}`}
			description="Read devotional stotras, slokas, and Telugu spiritual hymns with dedicated posts on In Tirupati."
		/>
		<style>
			main {
				width: 100% !important;
				max-width: 100% !important;
				margin: 0 !important;
				padding: 0 !important;
			}
			body {
				background-color: #f8fafc !important;
				font-family: var(--font-atkinson), ui-sans-serif, system-ui, sans-serif !important;
				color: #1e293b !important;
			}
		</style>
	</head>
	<body class="min-h-screen flex flex-col bg-slate-50 antialiased">
		<Header />

		<main class="flex-grow py-12 md:py-16">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="max-w-3xl mx-auto text-center mb-12">
					<h1 class="text-3xl font-black tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">
						List of Stotras - <span class="bg-gradient-to-r from-amber-600 to-orange-600 bg-clip-text text-transparent">స్తోత్రాలు</span>
					</h1>
					<p class="mt-4 text-base text-slate-600">
						A dedicated collection for devotional stotras, slokas, and spiritual hymn posts.
					</p>
				</div>

				{stotras.length > 0 ? (
					<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
						{stotras.map((post) => (
							<article class="flex flex-col justify-between overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm hover:shadow-md hover:border-amber-500/25 transition-all duration-200">
								<div class="p-6 space-y-2.5">
									<span class="inline-block text-xs font-semibold text-slate-400">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<h2 class="text-lg font-bold leading-snug">
										<a href={`/stotras/${post.id}/`} class="text-slate-900 hover:text-amber-700 transition-colors">
											{post.data.title}
										</a>
									</h2>
									<p class="text-sm text-slate-600 line-clamp-3 leading-relaxed">
										{post.data.description}
									</p>
								</div>
								<div class="border-t border-slate-100 p-6 pt-4 bg-slate-50/50">
									<a href={`/stotras/${post.id}/`} class="inline-flex items-center gap-1.5 text-xs font-bold text-amber-700 hover:text-amber-800 transition-colors uppercase tracking-wider">
										Read Stotra
									</a>
								</div>
							</article>
						))}
					</div>
				) : (
					<div class="mx-auto max-w-2xl rounded-xl border border-dashed border-slate-300 bg-white p-8 text-center text-slate-600">
						Stotra posts will appear here after you add them from the admin panel.
					</div>
				)}
			</div>
		</main>

		<Footer />
	</body>
</html>
