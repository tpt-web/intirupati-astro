---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import StotraLanguageLinks from '../../../components/StotraLanguageLinks.astro';
import TranslatedStotraContent from '../../../components/TranslatedStotraContent.astro';
import { transliterateStotraText } from '../../../lib/transliterateStotra';
import {
	type StotraLanguage,
	stotraBaseSlug,
	stotraLanguageLinkPath,
	stotraLanguagePath,
	stotraLanguages,
} from '../../../lib/stotraLanguages';

type Props = {
	post: CollectionEntry<'stotras'>;
	language: StotraLanguage;
};

export async function getStaticPaths() {
	const posts = await getCollection('stotras');

	return posts.flatMap((post) =>
		stotraLanguages.filter((language) => language.slug !== 'telugu').map((language) => ({
			params: {
				language: language.slug,
				slug: stotraBaseSlug(post.id),
			},
			props: { post, language },
		})),
	);
}

const { post, language } = Astro.props;
const { Content } = await render(post);
const baseTitle = post.data.title
	.replace(/\s*-\s*.*$/, '')
	.replace(/\s+Telugu\b/i, '')
	.trim();
const pageTitle = `${baseTitle} - ${language.label} Lyrics`;
const pageDescription = `Read ${baseTitle} in ${language.label}. Stotra lyrics generated from the original Telugu stotra post with a dedicated ${language.label} URL for easy reading.`;
const canonicalURL = new URL(stotraLanguagePath(post, language), Astro.site).toString();
const isTelugu = language.slug === 'telugu';
const nativeTitle = transliterateStotraText(pageTitle, language.scheme);
const displayTitle = `${baseTitle} (${nativeTitle})`;
const localizedSource = post.body
	.replace(/\bTelugu\b/gi, language.label)
	.replace(/తెలుగు/g, language.label)
	.replace(/\bEnglish Meaning\b/gi, `${language.label} Meaning`);
const alternateLinks = [
	...stotraLanguages.map((alternateLanguage) => ({
		hreflang: alternateLanguage.locale,
		href: new URL(stotraLanguageLinkPath(post, alternateLanguage), Astro.site).toString(),
	})),
	{
		hreflang: 'x-default',
		href: new URL(
			stotraLanguageLinkPath(post, stotraLanguages.find((alternateLanguage) => alternateLanguage.slug === 'telugu') ?? language),
			Astro.site,
		).toString(),
	},
];
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'CreativeWork',
	name: displayTitle,
	headline: displayTitle,
	description: pageDescription,
	url: canonicalURL,
	inLanguage: language.locale,
	isPartOf: {
		'@type': 'CollectionPage',
		name: 'List of Stotras',
		url: new URL('/stotras/', Astro.site).toString(),
	},
	datePublished: post.data.pubDate.toISOString(),
	dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
};

const adSlots = [
	{ slot: '7608753970', label: 'Sponsored Advertisement' },
	{ slot: '1924008995', label: 'Sponsored Advertisement' },
	{ slot: '4981061956', label: 'Sponsored Advertisement' },
];
---

<BlogPost
	{...post.data}
	title={displayTitle}
	description={pageDescription}
	adSlots={adSlots}
	canonicalURL={canonicalURL}
	structuredData={structuredData}
	alternateLinks={alternateLinks}
>
	<StotraLanguageLinks post={post} currentLanguage={language.slug} labelTitle={displayTitle} />
	{isTelugu ? <Content /> : <TranslatedStotraContent content={localizedSource} scheme={language.scheme} />}
</BlogPost>
