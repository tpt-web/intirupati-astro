---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { postCanonicalURL } from '../../lib/postUrls';
import HanumanChalisaSeoTags from '../../components/HanumanChalisaSeoTags.astro';
import StotraLanguageLinks from '../../components/StotraLanguageLinks.astro';
import {
	stotraLanguageLinkPath,
	stotraLanguages,
} from '../../lib/stotraLanguages';

export async function getStaticPaths() {
	const posts = await getCollection('stotras');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'stotras'>;

const post = Astro.props;
const { Content } = await render(post);
const canonicalURL = postCanonicalURL(post, Astro.site);
const showHanumanLanguageIndex = post.id === 'hanuman-chalisa-telugu';
const baseTitle = post.data.title
	.replace(/\s*-\s*.*$/, '')
	.replace(/\s+Telugu\b/i, '')
	.trim();
const alternateLinks = [
	...stotraLanguages.map((language) => ({
		hreflang: language.locale,
		href: new URL(stotraLanguageLinkPath(post, language), Astro.site).toString(),
	})),
	{ hreflang: 'x-default', href: canonicalURL },
];
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'CreativeWork',
	name: post.data.title,
	headline: post.data.title,
	description: post.data.description,
	url: canonicalURL,
	inLanguage: stotraLanguages.map((language) => language.locale),
	alternateName: stotraLanguages.map((language) => `${baseTitle} ${language.label} lyrics`),
	genre: ['Stotra', 'Devotional lyrics', 'Hindu prayer'],
	isPartOf: {
		'@type': 'CollectionPage',
		name: 'List of Stotras',
		url: new URL('/stotras/', Astro.site).toString(),
	},
	datePublished: post.data.pubDate.toISOString(),
	dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
};

const adSlots = [
	{ slot: '7608753970', label: 'Sponsored Advertisement' },
	{ slot: '1924008995', label: 'Sponsored Advertisement' },
	{ slot: '4981061956', label: 'Sponsored Advertisement' },
];
---

<BlogPost
	{...post.data}
	adSlots={adSlots}
	canonicalURL={canonicalURL}
	structuredData={structuredData}
	alternateLinks={alternateLinks}
>
	<Content />
	<StotraLanguageLinks post={post} currentLanguage="telugu" />
	{showHanumanLanguageIndex && <HanumanChalisaSeoTags />}
</BlogPost>
