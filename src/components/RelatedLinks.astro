---
interface RelatedLink {
	title: string;
	description: string;
	href: string;
	type?: string;
}

interface Props {
	links?: RelatedLink[];
}

const { links = [] } = Astro.props;
---

{links.length > 0 && (
	<section class="related-links" aria-labelledby="related-links-title">
		<h2 id="related-links-title">Related guides</h2>
		<div class="related-links__grid">
			{links.map((link) => (
				<a class="related-links__item" href={link.href}>
					{link.type && <span>{link.type}</span>}
					<strong>{link.title}</strong>
					<p>{link.description}</p>
				</a>
			))}
		</div>
	</section>
)}

<style>
	.related-links {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid #e2e8f0;
	}

	.related-links h2 {
		margin: 0 0 1rem;
		font-size: 1.35rem;
		line-height: 1.2;
		color: #0f172a;
	}

	.related-links__grid {
		display: grid;
		gap: 0.85rem;
	}

	.related-links__item {
		display: block;
		padding: 1rem;
		border: 1px solid #e2e8f0;
		border-radius: 8px;
		background: #fff;
		text-decoration: none;
		color: inherit;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.related-links__item:hover {
		border-color: #d97706;
		box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
		transform: translateY(-1px);
	}

	.related-links__item span {
		display: block;
		margin-bottom: 0.35rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #b45309;
	}

	.related-links__item strong {
		display: block;
		color: #0f172a;
		line-height: 1.35;
	}

	.related-links__item p {
		margin: 0.45rem 0 0;
		font-size: 0.92rem;
		line-height: 1.55;
		color: #475569;
	}
</style>
