---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import AdSenseBlock from '../components/AdSenseBlock.astro';

type RelatedLink = {
	title: string;
	description: string;
	href: string;
	type?: string;
};

type AdSlot = {
	slot: string;
	label?: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	relatedLinks?: RelatedLink[];
	adSlots?: AdSlot[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	relatedLinks = [],
	adSlots = [],
} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			ogType="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				max-width: 1020px;
				margin: 0 auto;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				max-width: 100%;
				height: auto;
			}
			.prose {
				width: 1020px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.article-ad {
				margin: 1.75rem 0;
			}
			@media (max-width: 640px) {
				main {
					width: 100%;
				}
				.hero-image {
					max-width: 100%;
				}
				.hero-image img {
					border-radius: 0;
				}
				.prose {
					width: 100%;
					max-width: 100%;
					padding: 1rem;
					overflow-wrap: anywhere;
				}
				.title {
					padding-top: 0.75rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && (
						typeof heroImage === 'string' ? (
							<img width={1020} height={510} src={heroImage} alt="" />
						) : (
							<Image width={1020} height={510} src={heroImage} alt="" />
						)
					)}
				</div>
				<div class="prose">
					<div class="title">
						{pubDate && (
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
						)}
						<h1>{title}</h1>
						<hr />
					</div>
					{adSlots[0] && (
						<div class="article-ad">
							<AdSenseBlock slot={adSlots[0].slot} label={adSlots[0].label} />
						</div>
					)}
					<slot />
					{adSlots[1] && (
						<div class="article-ad">
							<AdSenseBlock slot={adSlots[1].slot} label={adSlots[1].label} />
						</div>
					)}
					<RelatedLinks links={relatedLinks} />
					{adSlots[2] && (
						<div class="article-ad">
							<AdSenseBlock slot={adSlots[2].slot} label={adSlots[2].label} />
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
