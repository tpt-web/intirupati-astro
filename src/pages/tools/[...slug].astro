---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ToolPageLayout from '../../layouts/ToolPageLayout.astro';
import MeeshoCropTool from '../../components/tools/MeeshoCropTool.astro';
import TirumalaCrowdStatus from '../../components/tools/TirumalaCrowdStatus.astro';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	return tools.map((tool) => ({
		params: { slug: tool.id },
		props: tool,
	}));
}
type Props = CollectionEntry<'tools'>;

const tool = Astro.props;
const { slug } = Astro.params;
const { Content } = await render(tool);

const stopWords = new Set([
	'a', 'an', 'and', 'are', 'at', 'booking', 'by', 'complete', 'cost', 'darshan',
	'details', 'for', 'free', 'from', 'guide', 'how', 'in', 'info', 'is', 'label',
	'of', 'on', 'online', 'pooja', 'price', 'seva', 'temple', 'the', 'timings',
	'tirumala', 'tirupati', 'to', 'today', 'tool', 'with',
]);

function keywords(value: string) {
	return new Set(
		value
			.toLowerCase()
			.replace(/[^a-z0-9\s-]/g, ' ')
			.split(/[\s-]+/)
			.filter((word) => word.length > 2 && !stopWords.has(word)),
	);
}

const currentKeywords = keywords(`${tool.data.title} ${tool.data.description}`);
const allPosts = await getCollection('blog');
const allTools = await getCollection('tools');
const candidates = [
	...allTools
		.filter((entry) => entry.id !== tool.id)
		.map((entry) => ({
			title: entry.data.title,
			description: entry.data.description,
			href: `/tools/${entry.id}/`,
			type: 'Tool',
			date: entry.data.pubDate ?? new Date(0),
			keywords: keywords(`${entry.data.title} ${entry.data.description}`),
		})),
	...allPosts.map((entry) => ({
		title: entry.data.title,
		description: entry.data.description,
		href: `/blog/${entry.id}/`,
		type: 'Guide',
		date: entry.data.pubDate,
		keywords: keywords(`${entry.data.title} ${entry.data.description}`),
	})),
];

const relatedLinks = candidates
	.map((candidate) => ({
		...candidate,
		score: [...candidate.keywords].filter((word) => currentKeywords.has(word)).length,
	}))
	.sort((a, b) => b.score - a.score || b.date.valueOf() - a.date.valueOf())
	.slice(0, 5);
---

<ToolPageLayout {...tool.data} relatedLinks={relatedLinks}>
	<!-- Render interactive tool based on slug inside the 'tool' slot -->
	<Fragment slot="tool">
		{slug === 'meesho-label-crop-tool-free' && <MeeshoCropTool />}
		{slug === 'tirumala-tirupati-darshan-crowd-status-today-waiting-time-live' && <TirumalaCrowdStatus />}
	</Fragment>

	<!-- Render SEO copywriting/guide from markdown in the default slot -->
	<div class="prose prose-red max-w-none">
		<Content />
	</div>
</ToolPageLayout>
