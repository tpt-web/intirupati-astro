---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
  {posts.map((post) => (
    <article class="flex flex-col justify-between overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm hover:shadow-md hover:border-amber-500/25 transition-all duration-200">
      <div>
        {post.data.heroImage && (
          <div class="relative aspect-video w-full overflow-hidden bg-slate-100 border-b border-slate-100">
            {typeof post.data.heroImage === 'string' ? (
              <img 
                width={720} 
                height={360} 
                src={post.data.heroImage} 
                alt={post.data.title}
                class="h-full w-full object-cover hover:scale-[1.02] transition-transform duration-300"
                loading="lazy"
              />
            ) : (
              <Image 
                width={720} 
                height={360} 
                src={post.data.heroImage} 
                alt={post.data.title}
                class="h-full w-full object-cover hover:scale-[1.02] transition-transform duration-300"
                loading="lazy"
              />
            )}
          </div>
        )}
        
        <div class="p-6 space-y-2.5">
          <span class="inline-block text-xs font-semibold text-slate-400">
            <FormattedDate date={post.data.pubDate} />
          </span>
          
          <h3 class="text-lg font-bold leading-snug">
            <a href={`/blog/${post.id}/`} class="text-slate-900 hover:text-amber-700 transition-colors">{post.data.title}</a>
          </h3>
          
          {post.data.description && (
            <p class="text-sm text-slate-600 line-clamp-3 leading-relaxed">
              {post.data.description}
            </p>
          )}
        </div>
      </div>
      
      <div class="border-t border-slate-100 p-6 pt-4 bg-slate-50/50">
        <a 
          href={`/blog/${post.id}/`} 
          class="inline-flex items-center gap-1.5 text-xs font-bold text-amber-700 hover:text-amber-800 transition-colors uppercase tracking-wider"
        >
          Read Full Guide
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </article>
  ))}
</div>
