---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getRelatedBlogLinks } from '../../lib/relatedPosts';
import { postCanonicalURL } from '../../lib/postUrls';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection('blog');
const allTools = await getCollection('tools');
const relatedLinks = getRelatedBlogLinks(post, allPosts, allTools);

const adSlots = [
	{ slot: '7608753970', label: 'Sponsored Advertisement' },
	{ slot: '1924008995', label: 'Sponsored Advertisement' },
	{ slot: '4981061956', label: 'Sponsored Advertisement' },
];
---

<BlogPost
	{...post.data}
	relatedLinks={relatedLinks}
	adSlots={adSlots}
	canonicalURL={postCanonicalURL(post, Astro.site)}
>
	<Content />
</BlogPost>
