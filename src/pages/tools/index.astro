---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const tools = await getCollection('tools');
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead
			title={`Free Devotee & Seller Tools - ${SITE_TITLE}`}
			description="Useful online tools for Tirumala pilgrims and e-commerce sellers, including live crowd status tracking and shipping label crop tools."
			image="/images/2026/05/Meesho-Label-Crop-Tool-Free-intirupati.in_.webp"
		/>
		<style>
			main {
				width: 100% !important;
				max-width: 100% !important;
				margin: 0 !important;
				padding: 0 !important;
			}
			body {
				background-color: #f8fafc !important; /* slate-50 */
				font-family: var(--font-atkinson), ui-sans-serif, system-ui, sans-serif !important;
				font-size: 16px !important;
				line-height: 1.5 !important;
				color: #1e293b !important; /* slate-800 */
			}
		</style>
	</head>
	<body class="min-h-screen flex flex-col bg-slate-50 antialiased">
		<Header />
		
		<main class="flex-grow py-12 md:py-16">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				
				<!-- Page Header -->
				<div class="max-w-3xl mx-auto text-center mb-12 md:mb-16">
					<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-200 uppercase tracking-wider mb-3">
						🛠️ Free Utilities
					</span>
					<h1 class="text-3xl font-black tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">
						Devotee Utilities & <span class="bg-gradient-to-r from-amber-600 to-orange-600 bg-clip-text text-transparent">Seller Tools</span>
					</h1>
					<p class="mt-4 text-base text-slate-600">
						Explore our 100% free web utilities. Instantly crop and sort Meesho shipping labels, or check the live Tirupati darshan waiting times and crowd status before scheduling your trip.
					</p>
				</div>

				<!-- Tools Directory Grid -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
					
					<!-- Meesho Shipping Label Crop Card -->
					<div class="group bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">
						<div class="aspect-video w-full overflow-hidden bg-slate-100 relative">
							<img src="/images/2026/05/Meesho-Label-Crop-Tool-Free-intirupati.in_.webp" alt="Meesho Label Crop Tool" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
							<div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
							<span class="absolute bottom-4 left-4 inline-flex items-center gap-1 bg-red-600 text-white font-bold text-[10px] uppercase px-2.5 py-1 rounded shadow-md">
								⚡ Super Fast
							</span>
						</div>
						<div class="p-6 flex flex-col flex-grow">
							<h2 class="text-xl font-bold text-slate-900 group-hover:text-amber-600 transition-colors mb-2">
								Meesho Label Crop Tool Free
							</h2>
							<p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">
								Drag and drop your Meesho A4 shipping label PDF. Our smart cropper auto-detects individual pages, crops labels to 4x6 inch size for thermal printers, groups them by courier or SKU, and generates a print-ready PDF in seconds.
							</p>
							<div class="flex items-center justify-between mt-auto">
								<div class="flex gap-2">
									<span class="text-xs font-semibold text-slate-400 bg-slate-100 px-2.5 py-1 rounded">No Signup</span>
									<span class="text-xs font-semibold text-slate-400 bg-slate-100 px-2.5 py-1 rounded">Private</span>
								</div>
								<a href="/tools/meesho-label-crop-tool-free/" class="inline-flex items-center gap-1 text-sm font-bold text-amber-600 hover:text-amber-700 transition-colors">
									Open Tool <i class="fas fa-chevron-right text-[10px]"></i>
								</a>
							</div>
						</div>
					</div>

					<!-- Tirumala Live Status Card -->
					<div class="group bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">
						<div class="aspect-video w-full overflow-hidden bg-slate-100 relative">
							<img src="/images/2025/12/Tirumala-Darshan-Crowd-Status-Today-intirupati.in_-1024x683.webp" alt="Tirumala Darshan Crowd Status" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
							<div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
							<span class="absolute bottom-4 left-4 inline-flex items-center gap-1 bg-green-600 text-white font-bold text-[10px] uppercase px-2.5 py-1 rounded shadow-md">
								🟢 Live Update
							</span>
						</div>
						<div class="p-6 flex flex-col flex-grow">
							<h2 class="text-xl font-bold text-slate-900 group-hover:text-amber-600 transition-colors mb-2">
								Tirumala Live Darshan Crowd Status Today
							</h2>
							<p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">
								Track Tirumala queue compartments, wait hours for free (Sarva) and walker (Divya) darshan, and offline SSD token counts in Tirupathi counters. Dynamic updates from official reports and calendar estimations help you beat the rush.
							</p>
							<div class="flex items-center justify-between mt-auto">
								<div class="flex gap-2">
									<span class="text-xs font-semibold text-slate-400 bg-slate-100 px-2.5 py-1 rounded">Auto Scrape</span>
									<span class="text-xs font-semibold text-slate-400 bg-slate-100 px-2.5 py-1 rounded">Daily Stats</span>
								</div>
								<a href="/tools/tirumala-tirupati-darshan-crowd-status-today-waiting-time-live/" class="inline-flex items-center gap-1 text-sm font-bold text-amber-600 hover:text-amber-700 transition-colors">
									Check Status <i class="fas fa-chevron-right text-[10px]"></i>
								</a>
							</div>
						</div>
					</div>

				</div>
				
			</div>
		</main>

		<Footer />
	</body>
</html>
