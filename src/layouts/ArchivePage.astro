---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import BlogGrid from '../components/BlogGrid.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	posts: CollectionEntry<'blog'>[];
}

const { title, description, posts } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={`${title} - ${SITE_TITLE}`} description={description} />
		<style>
			main {
				width: 100% !important;
				max-width: 100% !important;
				margin: 0 !important;
				padding: 0 !important;
			}
			body {
				background-color: #f8fafc !important;
				font-family: var(--font-atkinson), ui-sans-serif, system-ui, sans-serif !important;
				color: #1e293b !important;
			}
		</style>
	</head>
	<body class="min-h-screen flex flex-col bg-slate-50 antialiased">
		<Header />
		<main class="flex-grow py-12 md:py-16">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="max-w-3xl mx-auto text-center mb-12">
					<h1 class="text-3xl font-black tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">
						{title}
					</h1>
					<p class="mt-4 text-base text-slate-600">{description}</p>
				</div>

				{posts.length > 0 ? (
					<BlogGrid posts={posts} />
				) : (
					<div class="mx-auto max-w-2xl rounded-lg border border-slate-200 bg-white p-8 text-center text-slate-600">
						No matching guides are available yet. Browse the latest posts from the blog.
					</div>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
