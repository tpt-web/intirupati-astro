---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';
import { SEO } from 'astro-seo';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	ogType?: 'website' | 'article';
	pubDate?: Date;
	updatedDate?: Date;
	canonicalURL?: string;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	ogType = 'website',
	pubDate,
	updatedDate,
	canonicalURL = new URL(Astro.url.pathname, Astro.site).toString(),
} = Astro.props;
const image = Astro.props.image || FallbackImage;
const imageSrc = typeof image === 'string' ? image : image.src;
const imageURL = new URL(imageSrc, Astro.site ?? Astro.url).toString();
const imageWidth = typeof image === 'string' ? undefined : image.width;
const imageHeight = typeof image === 'string' ? undefined : image.height;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="google-site-verification" content="nM9yaAy7RGjjrwrOw8W5ICuoI2bldO4hG2RQBNf2568" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />

<script async src="https://www.googletagmanager.com/gtag/js?id=G-BL1F7RBZND"></script>
<script is:inline>
	window.dataLayer = window.dataLayer || [];
	function gtag(){dataLayer.push(arguments);}
	gtag('js', new Date());
	gtag('config', 'G-BL1F7RBZND');
</script>

<script
	async
	src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5549925649870899"
	crossorigin="anonymous"
></script>

<SEO
	title={title}
	description={description}
	canonical={canonicalURL}
	openGraph={{
		basic: {
			title: title,
			type: ogType,
			image: imageURL,
			url: canonicalURL,
		},
		optional: {
			description: description,
			siteName: SITE_TITLE,
			locale: 'en_IN',
		},
		image: {
			width: imageWidth,
			height: imageHeight,
			alt: title,
		},
		article: ogType === 'article' ? {
			publishedTime: pubDate?.toISOString(),
			modifiedTime: updatedDate?.toISOString(),
		} : undefined,
	}}
	twitter={{
		card: 'summary_large_image',
		title: title,
		description: description,
		image: imageURL,
		imageAlt: title,
	}}
	extend={{
		link: [{ rel: 'icon', type: 'image/png', href: '/favicon.png' }],
	}}
/>
